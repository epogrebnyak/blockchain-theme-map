<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blockchain and Digital Assets Theme Map</title>
  <link rel="icon" href="favicon.svg" type="image/svg+xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      color-scheme: dark;
      --bg: #0f1117;
      --panel: #161f2d;
      --panel-strong: #111827;
      --line: #2d3b52;
      --text: #e2e8f0;
      --muted: #94a3b8;
      --blue: #60a5fa;
      --violet: #a78bfa;
      --green: #34d399;
      --amber: #fb923c;
      --red: #f87171;
      --cyan: #22d3ee;
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: radial-gradient(circle at top, #172033 0, var(--bg) 55%);
      color: var(--text);
      min-height: 100vh;
      padding: 24px 16px 48px;
    }

    header {
      max-width: 1180px;
      margin: 0 auto 32px;
      text-align: center;
    }

    header h1 {
      margin: 0;
      font-size: clamp(2rem, 3vw, 2.8rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      background: linear-gradient(135deg, var(--blue), var(--violet));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    header p {
      margin: 10px auto 0;
      max-width: 760px;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.6;
    }

    main {
      max-width: 1180px;
      margin: 0 auto;
      display: grid;
      gap: 28px;
    }

    .theme-group {
      display: grid;
      gap: 14px;
    }

    .group-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px;
    }

    .group-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 92px;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: 1px solid currentColor;
      background: rgba(15, 23, 42, 0.75);
    }

    .group-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
    }

    .group-note {
      color: var(--muted);
      font-size: 0.88rem;
    }

    .group1 .group-badge { color: var(--blue); }
    .layer2 .group-badge { color: var(--violet); }
    .layer3 .group-badge { color: var(--green); }
    .layer4 .group-badge { color: var(--amber); }
    .layer5 .group-badge { color: var(--red); }
    .layer6 .group-badge { color: var(--cyan); }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 14px;
    }

    .theme-group.horizontal .cards-grid {
      grid-template-columns: 1fr;
    }

    .card {
      background: linear-gradient(180deg, rgba(22, 31, 45, 0.98), rgba(15, 23, 42, 0.98));
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 18px 40px rgba(2, 8, 23, 0.28);
    }

    .card-header {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 14px;
    }

    .card-title {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
    }

    .card-subtitle {
      color: var(--muted);
      font-size: 0.86rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .content-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 14px;
    }

    .content-block {
      background: rgba(15, 23, 42, 0.72);
      border: 1px solid rgba(71, 85, 105, 0.45);
      border-radius: 14px;
      padding: 14px;
    }

    .content-block h3 {
      margin: 0 0 10px;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #cbd5e1;
    }

    ul {
      margin: 0;
      padding-left: 18px;
      color: var(--muted);
    }

    li + li {
      margin-top: 6px;
    }

    .single-list {
      display: grid;
      gap: 10px;
    }

    .single-list ul {
      margin: 0;
    }

    .threat-table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(71, 85, 105, 0.45);
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.72);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 760px;
    }

    th,
    td {
      padding: 12px 14px;
      border-bottom: 1px solid rgba(71, 85, 105, 0.45);
      text-align: left;
      vertical-align: top;
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.55;
    }

    thead th {
      background: rgba(17, 24, 39, 0.92);
      color: var(--text);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    tbody th {
      width: 28%;
      color: var(--text);
      font-size: 0.92rem;
      font-weight: 600;
      background: rgba(15, 23, 42, 0.48);
    }

    tr:last-child th,
    tr:last-child td {
      border-bottom: none;
    }

    footer {
      max-width: 1180px;
      margin: 48px auto 0;
      text-align: center;
      color: #475569;
      font-size: 0.78rem;
    }

    .repo-link {
      margin-top: 12px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #cbd5e1;
      text-decoration: none;
      font-size: 0.85rem;
      border: 1px solid #334155;
      border-radius: 8px;
      padding: 6px 10px;
    }

    footer a { color: var(--blue); text-decoration: none; }
    .repo-link:hover { background: #1e293b; }

    @media (max-width: 820px) {
      body {
        padding: 20px 12px 40px;
      }

      .card {
        padding: 16px;
      }

      table {
        min-width: 0;
      }

      .threat-table-wrap {
        border: none;
        background: transparent;
      }

      table,
      thead,
      tbody,
      tr,
      th,
      td {
        display: block;
      }

      thead {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        clip-path: inset(50%);
        white-space: nowrap;
        border: 0;
      }

      tr {
        margin-bottom: 14px;
        border: 1px solid rgba(71, 85, 105, 0.45);
        border-radius: 14px;
        overflow: hidden;
        background: rgba(15, 23, 42, 0.72);
      }

      tbody th,
      td {
        width: auto;
        border-bottom: 1px solid rgba(71, 85, 105, 0.45);
      }

      td:last-child {
        border-bottom: none;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Blockchain and Digital Assets Theme Map</h1>
    <p>Click any category to explore its topics</p>
  </header>

  <main>
    {% for group in groups %}
    <section class="theme-group {{ group.class|e }}{% if group.horizontal %} horizontal{% endif %}" aria-labelledby="{{ group.id|e }}">
      <div class="group-header">
        <span class="group-badge">{{ group.badge|e }}</span>
        <div>
          <div class="group-title" id="{{ group.id|e }}">{{ group.title|e }}</div>
          {% if group.note %}<div class="group-note">{{ group.note|e }}</div>{% endif %}
        </div>
      </div>
      <div class="cards-grid">
        {% for card in group.cards %}
        <article class="card">
          <div class="card-header">
            <h2 class="card-title">{{ card.title|e }}</h2>
            <span class="card-subtitle">{{ card.subtitle|e }}</span>
          </div>

          {% if card.layout == 'blocks' %}
          <div class="content-grid">
            {% for block in card.blocks %}
            <section class="content-block">
              <h3>{{ block.title|e }}</h3>
              <ul>
                {% for item in block.items %}
                <li>{{ item|e }}</li>
                {% endfor %}
              </ul>
            </section>
            {% endfor %}
          </div>
          {% elif card.layout == 'list' %}
          <div class="single-list">
            <ul>
              {% for item in card.items %}
              <li>{{ item|e }}</li>
              {% endfor %}
            </ul>
          </div>
          {% elif card.layout == 'table' %}
          <div class="threat-table-wrap">
            <table>
              <thead>
                <tr>
                  <th scope="col">Risk category</th>
                  <th scope="col">Description</th>
                  <th scope="col">Example or notes</th>
                </tr>
              </thead>
              <tbody>
                {% for row in card.rows %}
                <tr>
                  <th scope="row">{{ row.category|e }}</th>
                  <td>{{ row.description|e }}</td>
                  <td>{{ row.example|e }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  </main>

  <footer>
    <div>Data sourced from <a href="{{ source_href|default('themes.yaml') }}">{{ source_name|default('themes.yaml') }}</a> · Last revised {{ last_revised|default('July 21, 2026') }}</div>
    <a class="repo-link" href="{{ repository_url|default('https://github.com/epogrebnyak/blockchain-theme-map') }}" target="_blank" rel="noopener noreferrer" aria-label="View repository on GitHub">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      Repository
    </a>
  </footer>
</body>
</html>
