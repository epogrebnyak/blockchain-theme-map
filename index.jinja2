<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blockchain and Digital Assets Theme Map</title>
  <link rel="icon" href="favicon.svg" type="image/svg+xml" />
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #111827;
      background: #f8fafc;
      line-height: 1.5;
    }
    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 24px 16px 40px;
    }
    h1 {
      margin: 0 0 8px;
      font-size: 2rem;
    }
    .subtitle {
      margin: 0;
      color: #475569;
    }
    main {
      margin-top: 28px;
      display: grid;
      gap: 24px;
    }
    .group h2 {
      margin: 0 0 12px;
      font-size: 1.35rem;
      border-bottom: 1px solid #dbe2ea;
      padding-bottom: 6px;
    }
    .cards {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
    .card {
      background: #ffffff;
      border: 1px solid #dbe2ea;
      border-radius: 10px;
      padding: 14px;
    }
    .card-wide {
      grid-column: 1 / -1;
    }
    .card h3 {
      margin: 0;
      font-size: 1.05rem;
    }
    .card-subtitle {
      margin: 4px 0 12px;
      color: #64748b;
      font-size: 0.9rem;
    }
    .content-grid {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
    .content-block {
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 10px;
      background: #f8fafc;
    }
    .content-block h4 {
      margin: 0 0 8px;
      font-size: 0.9rem;
    }
    ul {
      margin: 0;
      padding-left: 18px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.92rem;
    }
    th,
    td {
      border: 1px solid #dbe2ea;
      padding: 8px;
      text-align: left;
      vertical-align: top;
    }
    thead th {
      background: #f1f5f9;
    }
    footer {
      margin-top: 28px;
      color: #475569;
      font-size: 0.9rem;
    }
    footer a { color: inherit; }
  </style>
</head>
<body>
  <div class="page">
    <header>
      <h1>Blockchain and Digital Assets Theme Map</h1>
      <p class="subtitle">Topics grouped by theme and layer.</p>
    </header>

    <main>
      {% for group in groups %}
      <section class="group">
        <h2>{{ group.title }}</h2>
        <div class="cards">
          {% for card in group.cards %}
          <article class="card{% if card.orientation in ['horizontal', 'table'] %} card-wide{% endif %}">
            <h3>{{ card.title }}</h3>
            {% if card.show_subtitle %}<p class="card-subtitle">{{ card.subtitle }}</p>{% endif %}

            {% if card.layout == 'blocks' %}
            <div class="content-grid">
              {% for block in card.blocks %}
              <section class="content-block">
                <h4>{{ block.title }}</h4>
                <ul>
                  {% for item in block["items"] %}
                  <li>{{ item }}</li>
                  {% endfor %}
                </ul>
              </section>
              {% endfor %}
            </div>
            {% elif card.layout == 'list' %}
            <ul>
              {% for item in card["items"] %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
            {% elif card.layout == 'table' %}
            <table>
              <thead>
                <tr>
                  <th scope="col">Risk category</th>
                  <th scope="col">Description</th>
                  <th scope="col">Example or notes</th>
                </tr>
              </thead>
              <tbody>
                {% for row in card.rows %}
                <tr>
                  <th scope="row">{{ row.category }}</th>
                  <td>{{ row.description }}</td>
                  <td>{{ row.example }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
            {% endif %}
          </article>
          {% endfor %}
        </div>
      </section>
      {% endfor %}
    </main>

    <footer>
      <div>Data source: <a href="{{ source_href|default('themes.yaml') }}">{{ source_name|default('themes.yaml') }}</a> · Last revised {{ last_revised|default('July 21, 2026') }}</div>
      <div><a href="{{ repository_url|default('https://github.com/epogrebnyak/blockchain-theme-map') }}" target="_blank" rel="noopener noreferrer">GitHub Repository</a></div>
    </footer>
  </div>
</body>
</html>
